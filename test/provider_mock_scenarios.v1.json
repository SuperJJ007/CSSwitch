          "method": "POST",
          "path": "/responses/v1/responses",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "gpt-5.2", "/max_output_tokens": 1}}},
          "action": {"type": "openai_responses_text_tool", "include_tool": false, "model": "gpt-5.2"}
        },
        {
          "id": "responses-reuse-formal",
          "phase": "reuse",
          "method": "POST",
          "path": "/responses/v1/responses",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "gpt-5.2", "/max_output_tokens": 65536}}},
          "action": {"type": "openai_responses_text_tool", "include_tool": false, "model": "gpt-5.2"}
        },
        {
          "id": "responses-restart-formal",
          "phase": "restart",
          "method": "POST",
          "path": "/responses/v1/responses",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "gpt-5.2", "/max_output_tokens": 65536}}},
          "action": {"type": "openai_responses_text_tool", "include_tool": false, "model": "gpt-5.2"}
        }
      ]
    },
    "installed_relay_matrix": {
      "description": "Relay discovery, force, thinking, schema normalization, Kimi request filtering, reuse, and restart.",
      "phases": ["discovery", "scratch", "formal", "reuse", "restart"],
      "steps": [
        {
          "id": "relay-discovery",
          "phase": "discovery",
          "method": "GET",
          "path": "/relay/v1/models",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}, "anthropic-version": {"equals": "2023-06-01"}}},
          "action": {"type": "models_json", "models": ["MiniMax-M2", "kimi-k2.7-code"]}
        },
        {
          "id": "relay-scratch-force",
          "phase": "scratch",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}, "anthropic-version": {"equals": "2023-06-01"}},
            "body": {"json": true, "required": ["/messages"], "equals": {"/model": "MiniMax-M2", "/max_tokens": 1}}
          },
          "action": {"type": "anthropic_json", "model": "MiniMax-M2"}
        },
        {
          "id": "relay-formal-force-schema",
          "phase": "formal",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/tools/0/input_schema/type", "/tools/1/input_schema/properties"],
              "equals": {"/model": "MiniMax-M2", "/thinking/type": "adaptive", "/tools/0/input_schema/type": "object", "/tools/1/input_schema": {"type": "object", "properties": {}}}
            }
          },
          "action": {"type": "anthropic_json", "model": "MiniMax-M2"}
        },
        {
          "id": "relay-formal-kimi-thinking-filter",
          "phase": "formal",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/tools/0/name", "/tools/1/name"],
              "absent": ["/tools/2", "/tool_choice"],
              "equals": {"/model": "kimi-k2.7-code", "/thinking/type": "enabled", "/thinking/budget_tokens": 1024, "/tools/0/name": "lookup", "/tools/1/name": "empty", "/tools/0/input_schema/type": "object"}
            }
          },
          "action": {"type": "anthropic_json", "model": "kimi-k2.7-code"}
        },
        {
          "id": "relay-formal-kimi-stream",
          "phase": "formal",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}},
            "body": {"json": true, "absent": ["/tool_choice"], "equals": {"/model": "kimi-k2.7-code", "/stream": true, "/thinking/type": "enabled", "/thinking/budget_tokens": 1024}}
          },
          "action": {"type": "kimi_sse"}
        },
        {
          "id": "relay-reuse-scratch",
          "phase": "reuse",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "MiniMax-M2", "/max_tokens": 1}}},
          "action": {"type": "anthropic_json", "model": "MiniMax-M2"}
        },
        {
          "id": "relay-reuse-formal",
          "phase": "reuse",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "MiniMax-M2"}}},
          "action": {"type": "anthropic_json", "model": "MiniMax-M2"}
        },
        {
          "id": "relay-restart-formal",
          "phase": "restart",
          "method": "POST",
          "path": "/relay/v1/messages",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "MiniMax-M2"}}},
          "action": {"type": "anthropic_json", "model": "MiniMax-M2"}
        }
      ]
    },
    "relay_siliconflow_proxy_positive": {
      "description": "HTTP proxy absolute-form fixture for the exact SiliconFlow host; no HTTPS or CONNECT.",
      "phases": ["formal"],
      "steps": [
        {
          "id": "siliconflow-exact-host",
          "phase": "formal",
          "method": "POST",
          "path": "http://api.siliconflow.cn/v1/messages",
          "checks": {
            "headers": {"host": {"equals": "api.siliconflow.cn"}, "authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}},
            "body": {"json": true, "required": ["/tools", "/tool_choice"], "equals": {"/tool_choice": {"type": "any"}}}
          },
          "action": {"type": "anthropic_json", "model": "siliconflow-mock"}
        }
      ]
    },
    "relay_siliconflow_proxy_evil_suffix": {
      "description": "HTTP proxy negative fixture proving a SiliconFlow-like suffix does not trigger the downgrade.",
      "phases": ["formal"],
      "steps": [
        {
          "id": "siliconflow-evil-suffix",
          "phase": "formal",
          "method": "POST",
          "path": "http://api.siliconflow.cn.evil/v1/messages",
          "checks": {
            "headers": {"host": {"equals": "api.siliconflow.cn.evil"}, "authorization": {"bearer_secret": "provider_key"}, "x-api-key": {"equals_secret": "provider_key"}},
            "body": {"json": true, "required": ["/tools", "/tool_choice"], "equals": {"/tool_choice": {"type": "tool", "name": "lookup"}}}
          },
          "action": {"type": "anthropic_json", "model": "siliconflow-negative-mock"}
        }
      ]
    },
    "retry_message_drop3_then_success": {
      "description": "Three retryable pre-header drops followed by a valid Anthropic response on the same step.",
      "phases": ["formal"],
      "steps": [
        {
          "id": "retry-message-four-attempts",
          "phase": "formal",
          "method": "POST",
          "path": "/retry/v1/messages",
          "checks": {"headers": {"x-api-key": {"equals_secret": "provider_key"}}, "body": {"json": true, "required": ["/messages"]}},
          "action": {"type": "drop_then_success", "drops": 3, "then": {"type": "anthropic_json", "model": "retry-mock"}}
        }
      ]
    },
    "keepalive_stream_delay_1_2s_then_anthropic_sse": {
      "description": "A first-byte delay longer than one second followed by a complete Anthropic SSE stream.",
      "phases": ["formal"],
      "steps": [
        {
          "id": "keepalive-delayed-stream",
          "phase": "formal",
          "method": "POST",
          "path": "/keepalive/v1/messages",
          "checks": {"headers": {"x-api-key": {"equals_secret": "provider_key"}}, "body": {"json": true, "equals": {"/stream": true}}},
          "action": {"type": "delay", "seconds": 1.2, "then": {"type": "anthropic_sse", "model": "keepalive-mock"}}
        }
      ]
    },
    "deepseek_status_matrix": {
      "description": "DeepSeek actual appended endpoint status mapping.",
      "phases": ["status-401", "status-403", "status-429", "status-503"],
