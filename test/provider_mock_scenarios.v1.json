          "id": "openai-chat-discovery",
          "phase": "discovery",
          "method": "GET",
          "path": "/openai/v1/models",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": false}},
          "action": {"type": "models_json", "models": ["glm-4.5", "glm-tool"]}
        },
        {
          "id": "openai-chat-scratch",
          "phase": "scratch",
          "method": "POST",
          "path": "/openai/v1/chat/completions",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": false, "anthropic-version": false},
            "body": {"json": true, "required": ["/messages"], "equals": {"/model": "glm-4.5", "/max_tokens": 1, "/stream": false}}
          },
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "glm-4.5"}
        },
        {
          "id": "openai-chat-formal",
          "phase": "formal",
          "method": "POST",
          "path": "/openai/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "glm-4.5", "/max_tokens": 1000000, "/stream": false}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": true, "model": "glm-4.5"}
        },
        {
          "id": "openai-chat-reuse-scratch",
          "phase": "reuse",
          "method": "POST",
          "path": "/openai/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "glm-4.5", "/max_tokens": 1}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "glm-4.5"}
        },
        {
          "id": "openai-chat-reuse-formal",
          "phase": "reuse",
          "method": "POST",
          "path": "/openai/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "glm-4.5", "/max_tokens": 1000000}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "glm-4.5"}
        },
        {
          "id": "openai-chat-restart-formal",
          "phase": "restart",
          "method": "POST",
          "path": "/openai/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "glm-4.5", "/max_tokens": 1000000}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "glm-4.5"}
        }
      ]
    },
    "installed_openai_responses_matrix": {
      "description": "Responses discovery, function call/result mapping, exact call IDs, cap, reuse, and restart.",
      "phases": ["discovery", "scratch", "formal", "reuse", "restart"],
      "steps": [
        {
          "id": "responses-discovery",
          "phase": "discovery",
          "method": "GET",
          "path": "/responses/v1/models",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": false}},
          "action": {"type": "models_json", "models": ["gpt-5.2", "gpt-tool"]}
        },
        {
          "id": "responses-scratch",
          "phase": "scratch",
          "method": "POST",
          "path": "/responses/v1/responses",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}, "x-api-key": false, "anthropic-version": false},
            "body": {"json": true, "required": ["/input"], "types": {"/input": "array"}, "equals": {"/model": "gpt-5.2", "/max_output_tokens": 1, "/stream": false}}
          },
          "action": {"type": "openai_responses_text_tool", "include_tool": false, "model": "gpt-5.2"}
        },
        {
          "id": "responses-formal-tools-results",
          "phase": "formal",
          "method": "POST",
          "path": "/responses/v1/responses",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/input/1/type", "/input/1/call_id", "/input/2/type", "/input/2/call_id", "/tools/0/name"],
              "types": {"/input": "array", "/tools": "array"},
              "equals": {
                "/model": "gpt-5.2",
                "/max_output_tokens": 65536,
                "/stream": false,
                "/input/1/type": "function_call",
                "/input/1/call_id": "toolu_1",
                "/input/2/type": "function_call_output",
                "/input/2/call_id": "toolu_1",
                "/tools/0/name": "lookup",
                "/tool_choice": "auto"
