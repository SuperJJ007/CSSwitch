{
  "schema": "csswitch.provider-mock-scenarios",
  "version": 1,
  "actions": [
    "anthropic_json",
    "anthropic_sse",
    "dsml",
    "openai_chat_text_tool",
    "openai_responses_text_tool",
    "kimi_sse",
    "models_json",
    "status",
    "malformed_json",
    "drop_before_headers",
    "drop_then_success",
    "delay",
    "stall",
    "truncated"
  ],
  "scenarios": {
    "installed_deepseek_matrix": {
      "description": "Repeatable DeepSeek upstream queue. Discovery is deliberately empty because native models are static.",
      "phases": ["discovery", "scratch", "formal", "reuse", "restart"],
      "steps": [
        {
          "id": "deepseek-scratch-off",
          "phase": "scratch",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {
              "content-type": {"contains": "application/json"},
              "anthropic-version": {"equals": "2023-06-01"},
              "x-api-key": {"equals_secret": "provider_key"},
              "authorization": false
            },
            "body": {
              "json": true,
              "required": ["/model", "/messages", "/max_tokens"],
              "types": {"/messages": "array"},
              "equals": {
                "/model": "deepseek-v4-pro",
                "/max_tokens": 1
              },
              "shape": ["/stream", "/tools", "/tool_choice"]
            }
          },
          "action": {"type": "anthropic_json", "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-formal-off",
          "phase": "formal",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {
              "anthropic-version": {"equals": "2023-06-01"},
              "x-api-key": {"equals_secret": "provider_key"}
            },
            "body": {
              "json": true,
              "required": ["/model", "/messages", "/max_tokens", "/thinking/type"],
              "equals": {
                "/model": "deepseek-v4-pro",
                "/max_tokens": 65536,
                "/thinking/type": "adaptive"
              }
            }
          },
          "action": {"type": "anthropic_json", "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-formal-detect",
          "phase": "formal",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {"x-api-key": {"equals_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/model", "/messages", "/tools"],
              "types": {"/tools": "array"},
              "equals": {"/model": "deepseek-v4-pro", "/max_tokens": 65536}
            }
          },
          "action": {"type": "dsml", "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-formal-rewrite",
          "phase": "formal",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {"x-api-key": {"equals_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/model", "/messages", "/tools"],
              "types": {"/tools": "array"},
              "equals": {"/model": "deepseek-v4-pro", "/max_tokens": 65536}
            }
          },
          "action": {"type": "dsml", "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-formal-rewrite-stream",
          "phase": "formal",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {"x-api-key": {"equals_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/model", "/messages", "/tools", "/stream"],
              "equals": {"/model": "deepseek-v4-pro", "/max_tokens": 65536, "/stream": true}
            }
          },
          "action": {"type": "dsml", "stream": true, "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-reuse-scratch",
          "phase": "reuse",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {"x-api-key": {"equals_secret": "provider_key"}},
            "body": {"json": true, "equals": {"/model": "deepseek-v4-pro", "/max_tokens": 1}}
          },
          "action": {"type": "anthropic_json", "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-reuse-formal",
          "phase": "reuse",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {"x-api-key": {"equals_secret": "provider_key"}},
            "body": {"json": true, "equals": {"/model": "deepseek-v4-pro", "/max_tokens": 65536}}
          },
          "action": {"type": "anthropic_json", "model": "deepseek-v4-pro"}
        },
        {
          "id": "deepseek-restart-formal",
          "phase": "restart",
          "method": "POST",
          "path": "/deepseek/v1/messages",
          "checks": {
            "headers": {"x-api-key": {"equals_secret": "provider_key"}},
            "body": {"json": true, "equals": {"/model": "deepseek-v4-pro", "/max_tokens": 65536}}
          },
          "action": {"type": "anthropic_json", "model": "deepseek-v4-pro"}
        }
      ]
    },
    "installed_qwen_matrix": {
      "description": "Repeatable Qwen Chat, tools, results, stream replay, reuse, and restart queue.",
      "phases": ["discovery", "scratch", "formal", "reuse", "restart"],
      "steps": [
        {
          "id": "qwen-scratch",
          "phase": "scratch",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {
            "headers": {
              "authorization": {"bearer_secret": "provider_key"},
              "x-api-key": false,
              "anthropic-version": false
            },
            "body": {
              "json": true,
              "required": ["/model", "/messages", "/max_tokens", "/stream"],
              "equals": {"/model": "qwen3.7-max", "/max_tokens": 1, "/stream": false},
              "types": {"/messages": "array"}
            }
          },
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "qwen3.7-max"}
        },
        {
          "id": "qwen-formal-chat",
          "phase": "formal",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}},
            "body": {"json": true, "equals": {"/model": "qwen3.7-max", "/max_tokens": 8192, "/stream": false}}
          },
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "qwen3.7-max"}
        },
        {
          "id": "qwen-formal-tools-results",
          "phase": "formal",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}},
            "body": {
              "json": true,
              "required": ["/tools", "/tool_choice", "/messages/1/tool_calls/0/function/name", "/messages/2/tool_call_id"],
              "types": {"/tools": "array"},
              "equals": {
                "/model": "qwen3.7-max",
                "/max_tokens": 8192,
                "/stream": false,
                "/messages/1/tool_calls/0/function/name": "lookup",
                "/messages/2/role": "tool",
                "/messages/2/tool_call_id": "toolu_1",
                "/tool_choice": {"type": "function", "function": {"name": "lookup"}}
              }
            }
          },
          "action": {"type": "openai_chat_text_tool", "include_tool": true, "tool_name": "grade", "model": "qwen3.7-max"}
        },
        {
          "id": "qwen-formal-stream",
          "phase": "formal",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {
            "headers": {"authorization": {"bearer_secret": "provider_key"}},
            "body": {"json": true, "equals": {"/model": "qwen3.7-max", "/max_tokens": 8192, "/stream": false}}
          },
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "text": "mock qwen stream", "model": "qwen3.7-max"}
        },
        {
          "id": "qwen-reuse-scratch",
          "phase": "reuse",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "qwen3.7-max", "/max_tokens": 1}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "qwen3.7-max"}
        },
        {
          "id": "qwen-reuse-formal",
          "phase": "reuse",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "qwen3.7-max", "/max_tokens": 8192}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "qwen3.7-max"}
        },
        {
          "id": "qwen-restart-formal",
          "phase": "restart",
          "method": "POST",
          "path": "/qwen/v1/chat/completions",
          "checks": {"headers": {"authorization": {"bearer_secret": "provider_key"}}, "body": {"json": true, "equals": {"/model": "qwen3.7-max", "/max_tokens": 8192}}},
          "action": {"type": "openai_chat_text_tool", "include_tool": false, "model": "qwen3.7-max"}
        }
      ]
    },
    "installed_openai_chat_matrix": {
      "description": "Custom OpenAI discovery and repeated forced-model Chat requests without the Responses cap.",
      "phases": ["discovery", "scratch", "formal", "reuse", "restart"],
